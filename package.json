{
  "name": "apexcss-cli",
  "version": "0.3.0",
  "description": "ApexCSS CLI - Build and customize your CSS framework",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "./types/index.d.ts",
  "files": [
    "bin/",
    "dist/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "apexcss": "dist/bin/apexcss-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "tsx tests/run-tests.ts",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:watch": "tsx --test --watch tests/unit/**/*.test.ts",
    "test:coverage": "c8 tsx tests/run-tests.ts",
    "test:coverage:text": "c8 --reporter=text --reporter=text-summary tsx tests/run-tests.ts",
    "test:coverage:html": "c8 --reporter=html tsx tests/run-tests.ts",
    "lint": "biome lint cli/ bin/ tests/",
    "lint:fix": "biome lint cli/ bin/ tests/ --write",
    "format": "biome format cli/ bin/ tests/",
    "format:fix": "biome format cli/ bin/ tests/ --write",
    "check": "biome check cli/ bin/ tests/",
    "check:fix": "biome check cli/ bin/ tests/ --write",
    "doctor": "node dist/bin/apexcss-cli.js doctor",
    "version": "node dist/bin/apexcss-cli.js --version",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "css",
    "framework",
    "cli",
    "apexcss",
    "utility-first",
    "sass",
    "scss",
    "build-tool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris-briddock/apex-cli.git"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^22.19.20",
    "c8": "^11.0.0",
    "tsx": "^4.22.1",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "chokidar": "^3.6.0",
    "commander": "^14.0.3",
    "inquirer": "^13.4.1"
  },
  "peerDependencies": {
    "apexcss": "^0.4.1",
    "sass": ">=1.99.0",
    "vite": ">=8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
