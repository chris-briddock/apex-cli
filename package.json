{
  "name": "apexcss-cli",
  "version": "0.1.4",
  "description": "ApexCSS CLI - Build and customize your CSS framework",
  "type": "module",
  "main": "cli/index.js",
  "types": "./package.json",
  "files": [
    "bin/",
    "cli/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "apexcss": "bin/apexcss-cli.js"
  },
  "scripts": {
    "test": "node tests/run-tests.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:watch": "node --test --watch tests/unit/**/*.test.js",
    "test:coverage": "c8 node tests/run-tests.js",
    "test:coverage:text": "c8 --reporter=text --reporter=text-summary node tests/run-tests.js",
    "test:coverage:html": "c8 --reporter=html node tests/run-tests.js",
    "lint": "biome lint cli/ bin/ tests/",
    "lint:fix": "biome lint cli/ bin/ tests/ --write",
    "format": "biome format cli/ bin/ tests/",
    "format:fix": "biome format cli/ bin/ tests/ --write",
    "check": "biome check cli/ bin/ tests/",
    "check:fix": "biome check cli/ bin/ tests/ --write",
    "doctor": "node bin/apexcss-cli.js doctor",
    "version": "node bin/apexcss-cli.js --version",
    "prepublishOnly": "echo \"Preparing for publish...\""
  },
  "keywords": [
    "css",
    "framework",
    "cli",
    "apexcss",
    "utility-first",
    "sass",
    "scss",
    "build-tool"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris-briddock/apex-cli.git"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "c8": "^11.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "chokidar": "^3.6.0",
    "inquirer": "^13.4.1"
  },
  "optionalDependencies": {

  },
  "peerDependencies": {
    "apexcss": "^0.4.1",
    "sass": ">=1.99.0",
    "vite": ">=8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
